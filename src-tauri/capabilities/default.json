{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/nicegui/native/capabilities-schema.json",
  "identifier": "default",
  "description": "Default capabilities for NoobClaw",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "name": "binaries/noobclaw-server",
          "sidecar": true
        }
      ]
    },
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "dialog:default",
    "deep-link:default",
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "notification:default",
    "notification:allow-notify",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
